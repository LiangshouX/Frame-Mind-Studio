# FrameMind Studio - Environment Configuration
# Copy this file to .env and fill in your API keys

# ===== LLM API Keys (at least one required) =====
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# ===== AI Provider (openai/dashscope/anthropic/deepseek) =====
AI_PROVIDER=openai

# ===== Database =====
POSTGRES_USER=framemind
POSTGRES_PASSWORD=framemind_dev
POSTGRES_DB=framemind

# ===== Security =====
# Fernet key for API key encryption (auto-generated if empty)
FERNET_KEY=
