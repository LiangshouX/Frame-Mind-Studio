# FrameMind Studio - Environment Configuration
# Copy this file to .env and fill in your API keys

# ===== LLM API Keys (at least one required) =====
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# ===== AI Provider (openai/dashscope/anthropic/deepseek) =====
AI_PROVIDER=openai

# ===== Database =====
POSTGRES_USER=framemind
POSTGRES_PASSWORD=framemind_dev
POSTGRES_DB=framemind

# ===== Security =====
# Fernet key for API key encryption (auto-generated if empty)
FERNET_KEY=

# ===== OpenClaw 配置（Webhook 模式）=====
OPENCLAW_GATEWAY_URL=http://47.108.28.113:13015
OPENCLAW_WEBHOOK_ROUTE_ID=platform
OPENCLAW_WEBHOOK_SECRET=framemind
OPENCLAW_ENABLED=true
OPENCLAW_REQUEST_TIMEOUT_MS=120000
OPENCLAW_CONNECT_TIMEOUT_MS=10000
OPENCLAW_POLL_INTERVAL_MS=2000
OPENCLAW_MAX_POLL_RETRIES=120
