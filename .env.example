# FrameMind Studio - Environment Configuration
# Copy this file to .env and fill in your API keys

# ===== LLM API Keys (at least one required) =====
OPENAI_API_KEY=
QWEN_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# ===== Database =====
POSTGRES_USER=framemind
POSTGRES_PASSWORD=framemind_dev
POSTGRES_DB=framemind
DATABASE_URL=postgresql+asyncpg://framemind:framemind_dev@postgres:5432/framemind

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== ChromaDB =====
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ===== Security =====
# Auto-generated on first run if empty
FERNET_KEY=
